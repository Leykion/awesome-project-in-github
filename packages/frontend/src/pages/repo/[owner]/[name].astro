---
// packages/frontend/src/pages/repo/[owner]/[name].astro
// 项目详情页：仓库完整信息 + AI 策展分析 + 星标历史

import { computeHealthBadge } from "@gitpulse/shared";
import HealthBadge from "../../../components/astro/HealthBadge.astro";
import IntegrationBadges from "../../../components/astro/IntegrationBadges.astro";
import LicenseBadge from "../../../components/astro/LicenseBadge.astro";
import MetricsBar from "../../../components/astro/MetricsBar.astro";
import ScoreBreakdown from "../../../components/astro/ScoreBreakdown.astro";
import { StarChart } from "../../../components/react/StarChart";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { loadRepositories, loadStarHistory } from "../../../lib/data-loader";
import { formatNumber, timeAgo } from "../../../lib/format";

import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

export const getStaticPaths = (async () => {
  const repos = await loadRepositories();
  return repos.map((repo) => ({
    params: { owner: repo.owner, name: repo.name },
    props: { repo },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { repo } = Astro.props as Props;
const starHistory = await loadStarHistory();
const repoHistory = starHistory[repo.fullName] || [];

const healthStatus = computeHealthBadge({
  pushedAt: repo.pushedAt,
  openIssues: repo.openIssues,
  hasCi: repo.badges.hasCi,
  hasReleases: repo.badges.hasReleases,
  isArchived: repo.isArchived,
});
---

<BaseLayout title={`${repo.fullName} - GitPulse AI`} description={repo.curation?.oneLiner || repo.description || `${repo.fullName} 项目详情`}>
  <div class="mx-auto px-[var(--space-4)] py-[var(--space-8)]" style={`max-width: var(--max-width)`}>
    <!-- 项目头部 -->
    <header class="mb-[var(--space-8)]">
      <!-- 仓库名称 -->
      <div class="flex items-center gap-[var(--space-2)] mb-[var(--space-2)]">
        <h1 class="font-[var(--font-display)] text-[var(--text-2xl)] font-bold text-[var(--color-text-primary)]">
          <span class="text-[var(--color-text-secondary)]">{repo.owner}</span>
          <span class="text-[var(--color-text-tertiary)]"> / </span>
          <span>{repo.name}</span>
        </h1>
      </div>

      <!-- 描述 -->
      <p class="text-[var(--text-base)] text-[var(--color-text-secondary)] leading-[var(--leading-relaxed)] mb-[var(--space-4)] max-w-3xl">
        {repo.curation?.oneLiner || repo.description || '暂无描述'}
      </p>

      <!-- 徽章行 -->
      <div class="flex items-center gap-[var(--space-3)] flex-wrap mb-[var(--space-4)]">
        <HealthBadge status={healthStatus} />
        <LicenseBadge spdx={repo.licenseSpdx} />
        {repo.language && (
          <span class="inline-flex items-center gap-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-text-secondary)]">
            <span
              class="inline-block w-3 h-3 rounded-full"
              style={`background-color: ${repo.languageColor || 'var(--color-text-tertiary)'};`}
            ></span>
            {repo.language}
          </span>
        )}
        <span class="inline-flex items-center rounded-[var(--radius-full)] px-[var(--space-2)] py-0.5 text-[var(--text-xs)] font-medium text-[var(--color-accent)] bg-[var(--color-accent-dim)]">
          {repo.tier === 'star' ? 'Star' : repo.tier === 'notable' ? 'Notable' : 'Tracked'}
        </span>
      </div>

      <!-- 指标行 -->
      <MetricsBar stars={repo.stars} forks={repo.forks} pushedAt={repo.pushedAt} />

      <!-- 集成徽章行 -->
      <div class="mt-[var(--space-3)]">
        <IntegrationBadges badges={repo.badges} />
      </div>

      <!-- Topics -->
      {repo.topics.length > 0 && (
        <div class="flex items-center gap-[var(--space-1)] flex-wrap mt-[var(--space-4)]">
          {repo.topics.map((topic) => (
            <span class="inline-flex items-center rounded-[var(--radius-full)] px-[var(--space-2)] py-0.5 text-[var(--text-xs)] text-[var(--color-text-secondary)] bg-[var(--color-elevated)] border border-[var(--color-border)]">
              {topic}
            </span>
          ))}
        </div>
      )}

      <!-- 外部链接 -->
      <div class="flex items-center gap-[var(--space-4)] mt-[var(--space-4)]">
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-accent)] hover:underline"
        >
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
          </svg>
          GitHub
        </a>
        {repo.homepageUrl && (
          <a
            href={repo.homepageUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-accent)] hover:underline"
          >
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25Zm-.025 5.463a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 0 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 1 0 4.95 4.95l1.25-1.25Z" />
            </svg>
            项目主页
          </a>
        )}
        <a
          href={`/compare?repos=${repo.fullName}`}
          class="inline-flex items-center gap-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M9.573.677L7.177 3.073a.25.25 0 0 0 .177.427h1.146v3h2V3.5h1.146a.25.25 0 0 0 .176-.427L9.75.677a.25.25 0 0 0-.354 0ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm-2.25.75a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25ZM11 2.5h-1V4h1a1 1 0 0 1 1 1v5.628a2.251 2.251 0 1 0 1.5 0V5A2.5 2.5 0 0 0 11 2.5Zm1 10.25a.75.75 0 1 1 1.5 0 .75.75 0 0 1-1.5 0ZM3.75 12a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Z" />
          </svg>
          对比
        </a>
      </div>
    </header>

    <!-- 两列布局：主内容 + 侧边栏 -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-[var(--space-8)]">
      <!-- 左侧主内容 -->
      <div class="space-y-[var(--space-8)]">
        <!-- 星标历史图表 -->
        <section>
          <h2 class="text-[var(--text-lg)] font-semibold text-[var(--color-text-primary)] mb-[var(--space-4)]">
            星标趋势
          </h2>
          <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-[var(--space-4)]">
            {repoHistory.length < 2 ? (
              <div class="flex items-center justify-center py-[var(--space-8)] text-[var(--text-sm)] text-[var(--color-text-tertiary)]">
                数据积累中，暂无足够数据生成趋势图
              </div>
            ) : (
              <StarChart client:visible data={repoHistory} height={120} />
            )}
          </div>
        </section>

        <!-- AI 策展分析区域 -->
        <section>
          <h2 class="text-[var(--text-lg)] font-semibold text-[var(--color-text-primary)] mb-[var(--space-4)]">
            AI 分析
          </h2>

          {repo.curation ? (
            <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-[var(--space-6)] space-y-[var(--space-6)]">
              <!-- 摘要 -->
              <div>
                <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-[var(--space-2)]">
                  项目摘要
                </h3>
                <p class="text-[var(--text-base)] text-[var(--color-text-primary)] leading-[var(--leading-relaxed)]">
                  {repo.curation.summary}
                </p>
              </div>

              <!-- 为什么值得关注 -->
              {repo.curation.whyNotable && (
                <div>
                  <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-[var(--space-2)]">
                    为什么值得关注
                  </h3>
                  <p class="text-[var(--text-base)] text-[var(--color-text-primary)] leading-[var(--leading-relaxed)]">
                    {repo.curation.whyNotable}
                  </p>
                </div>
              )}

              <!-- 优势 -->
              {repo.curation.strengths.length > 0 && (
                <div>
                  <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-positive)] uppercase tracking-wider mb-[var(--space-2)]">
                    优势
                  </h3>
                  <ul class="list-disc list-inside space-y-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-text-primary)]">
                    {repo.curation.strengths.map((s) => <li>{s}</li>)}
                  </ul>
                </div>
              )}

              <!-- 局限性 -->
              {repo.curation.limitations.length > 0 && (
                <div>
                  <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-decline)] uppercase tracking-wider mb-[var(--space-2)]">
                    局限性
                  </h3>
                  <ul class="list-disc list-inside space-y-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-text-primary)]">
                    {repo.curation.limitations.map((l) => <li>{l}</li>)}
                  </ul>
                </div>
              )}

              <!-- 使用场景 -->
              {repo.curation.useCases.length > 0 && (
                <div>
                  <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-[var(--space-2)]">
                    使用场景
                  </h3>
                  <ul class="list-disc list-inside space-y-[var(--space-1)] text-[var(--text-sm)] text-[var(--color-text-primary)]">
                    {repo.curation.useCases.map((u) => <li>{u}</li>)}
                  </ul>
                </div>
              )}

              <!-- 目标用户和学习曲线 -->
              <div class="flex items-center gap-[var(--space-6)] flex-wrap text-[var(--text-sm)]">
                {repo.curation.targetAudience && (
                  <div>
                    <span class="text-[var(--color-text-tertiary)]">目标用户：</span>
                    <span class="text-[var(--color-text-primary)]">{repo.curation.targetAudience}</span>
                  </div>
                )}
                {repo.curation.learningCurve && (
                  <div>
                    <span class="text-[var(--color-text-tertiary)]">学习曲线：</span>
                    <span class="text-[var(--color-text-primary)]">
                      {repo.curation.learningCurve === 'low' ? '低' : repo.curation.learningCurve === 'medium' ? '中' : '高'}
                    </span>
                  </div>
                )}
              </div>

              <!-- 分析元信息 -->
              <div class="pt-[var(--space-3)] border-t border-[var(--color-border)] text-[var(--text-xs)] text-[var(--color-text-tertiary)]">
                分析模型：{repo.curation.modelUsed} | 分析时间：{timeAgo(repo.curation.evaluatedAt)}
              </div>
            </div>
          ) : (
            <div class="rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] p-[var(--space-6)]">
              <div class="flex flex-col items-center justify-center text-center py-[var(--space-4)]">
                <span class="text-3xl mb-[var(--space-3)]">🤖</span>
                <p class="text-[var(--text-base)] font-medium text-[var(--color-text-secondary)] mb-[var(--space-1)]">
                  AI 分析待生成
                </p>
                <p class="text-[var(--text-sm)] text-[var(--color-text-tertiary)]">
                  AI 策展分析将在下次自动化管道运行时生成
                </p>
              </div>
            </div>
          )}
        </section>
      </div>

      <!-- 右侧边栏 -->
      <aside class="space-y-[var(--space-6)]">
        <!-- 评分分解 -->
        <ScoreBreakdown scores={repo.scores} tier={repo.tier} />

        <!-- 仓库详细信息 -->
        <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-[var(--space-4)]">
          <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-[var(--space-3)]">
            仓库信息
          </h3>
          <dl class="space-y-[var(--space-3)] text-[var(--text-sm)]">
            <div class="flex items-center justify-between">
              <dt class="text-[var(--color-text-tertiary)]">Stars</dt>
              <dd class="font-[var(--font-data)] text-[var(--color-text-primary)]">{formatNumber(repo.stars)}</dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-[var(--color-text-tertiary)]">Forks</dt>
              <dd class="font-[var(--font-data)] text-[var(--color-text-primary)]">{formatNumber(repo.forks)}</dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-[var(--color-text-tertiary)]">Open Issues</dt>
              <dd class="font-[var(--font-data)] text-[var(--color-text-primary)]">{formatNumber(repo.openIssues)}</dd>
            </div>
            {repo.contributorCount !== null && (
              <div class="flex items-center justify-between">
                <dt class="text-[var(--color-text-tertiary)]">贡献者</dt>
                <dd class="font-[var(--font-data)] text-[var(--color-text-primary)]">{formatNumber(repo.contributorCount)}</dd>
              </div>
            )}
            <div class="flex items-center justify-between">
              <dt class="text-[var(--color-text-tertiary)]">最近提交</dt>
              <dd class="text-[var(--color-text-primary)]">{timeAgo(repo.pushedAt)}</dd>
            </div>
            {repo.createdAt && (
              <div class="flex items-center justify-between">
                <dt class="text-[var(--color-text-tertiary)]">创建于</dt>
                <dd class="text-[var(--color-text-primary)]">{timeAgo(repo.createdAt)}</dd>
              </div>
            )}
            <div class="flex items-center justify-between">
              <dt class="text-[var(--color-text-tertiary)]">默认分支</dt>
              <dd class="text-[var(--color-text-primary)]">{repo.defaultBranch}</dd>
            </div>
          </dl>
        </div>

        <!-- 可比较项目 -->
        {repo.curation?.comparableProjects && repo.curation.comparableProjects.length > 0 && (
          <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-[var(--space-4)]">
            <h3 class="text-[var(--text-sm)] font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-[var(--space-3)]">
              相关项目
            </h3>
            <div class="space-y-[var(--space-2)]">
              {repo.curation.comparableProjects.map((project) => (
                <a
                  href={`/repo/${project}`}
                  class="block text-[var(--text-sm)] text-[var(--color-accent)] hover:underline"
                >
                  {project}
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>

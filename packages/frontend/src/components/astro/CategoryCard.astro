---
// packages/frontend/src/components/astro/CategoryCard.astro
// 分类导航卡片：图标 + 名称 + 仓库计数

interface Props {
  /** 分类 slug */
  slug: string;
  /** 分类显示名称 */
  name: string;
  /** 分类图标 (emoji) */
  icon: string;
  /** 该分类下仓库数量 */
  repoCount: number;
}

const { slug, name, icon, repoCount } = Astro.props;
---

<a
  href={`/category/${slug}`}
  class="category-card group flex flex-col items-center justify-center rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-[var(--space-6)] text-center transition-all"
  style={`transition-duration: var(--duration-normal); transition-timing-function: var(--ease-out-expo);`}
>
  <!-- 图标 -->
  <span class="text-3xl mb-[var(--space-3)]">{icon}</span>

  <!-- 名称 -->
  <span class="text-[var(--text-sm)] font-semibold text-[var(--color-text-primary)] mb-[var(--space-1)]">
    {name}
  </span>

  <!-- 仓库计数 -->
  <span class="text-[var(--text-xs)] text-[var(--color-text-tertiary)] font-[var(--font-data)]">
    {repoCount} 个项目
  </span>
</a>

<style>
  .category-card:hover {
    transform: translateY(-2px);
    background-color: var(--color-elevated);
  }
</style>

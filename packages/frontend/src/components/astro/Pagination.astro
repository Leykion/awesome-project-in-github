---
// packages/frontend/src/components/astro/Pagination.astro
// 分页组件

interface Props {
  /** 当前页码 (1-based) */
  currentPage: number;
  /** 总页数 */
  totalPages: number;
  /** 基础 URL 路径（分页参数会附加在后面） */
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

// 生成页码列表（最多显示 7 个，中间省略）
function getPageNumbers(current: number, total: number): (number | "...")[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  const pages: (number | "...")[] = [1];
  if (current > 3) pages.push("...");
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  for (let i = start; i <= end; i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push("...");
  pages.push(total);
  return pages;
}

const pages = getPageNumbers(currentPage, totalPages);

function pageUrl(page: number): string {
  if (page === 1) return baseUrl;
  const separator = baseUrl.includes("?") ? "&" : "?";
  return `${baseUrl}${separator}page=${page}`;
}
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-[var(--space-1)]" aria-label="分页导航">
    <!-- 上一页 -->
    {currentPage > 1 ? (
      <a
        href={pageUrl(currentPage - 1)}
        class="flex items-center justify-center w-8 h-8 rounded-[var(--radius-md)] text-[var(--text-sm)] text-[var(--color-text-secondary)] hover:bg-[var(--color-elevated)] transition-colors"
        aria-label="上一页"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M9.78 12.78a.75.75 0 0 1-1.06 0L4.47 8.53a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 1.06L6.06 8l3.72 3.72a.75.75 0 0 1 0 1.06Z" /></svg>
      </a>
    ) : (
      <span class="flex items-center justify-center w-8 h-8 rounded-[var(--radius-md)] text-[var(--text-sm)] text-[var(--color-text-tertiary)] cursor-not-allowed">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M9.78 12.78a.75.75 0 0 1-1.06 0L4.47 8.53a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 1.06L6.06 8l3.72 3.72a.75.75 0 0 1 0 1.06Z" /></svg>
      </span>
    )}

    <!-- 页码 -->
    {pages.map((page) =>
      page === '...' ? (
        <span class="flex items-center justify-center w-8 h-8 text-[var(--text-sm)] text-[var(--color-text-tertiary)]">
          ...
        </span>
      ) : page === currentPage ? (
        <span
          class="flex items-center justify-center w-8 h-8 rounded-[var(--radius-md)] text-[var(--text-sm)] font-medium bg-[var(--color-accent)] text-[var(--color-ink)]"
          aria-current="page"
        >
          {page}
        </span>
      ) : (
        <a
          href={pageUrl(page)}
          class="flex items-center justify-center w-8 h-8 rounded-[var(--radius-md)] text-[var(--text-sm)] text-[var(--color-text-secondary)] hover:bg-[var(--color-elevated)] transition-colors"
        >
          {page}
        </a>
      )
    )}

    <!-- 下一页 -->
    {currentPage < totalPages ? (
      <a
        href={pageUrl(currentPage + 1)}
        class="flex items-center justify-center w-8 h-8 rounded-[var(--radius-md)] text-[var(--text-sm)] text-[var(--color-text-secondary)] hover:bg-[var(--color-elevated)] transition-colors"
        aria-label="下一页"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M6.22 3.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 0 1 0-1.06Z" /></svg>
      </a>
    ) : (
      <span class="flex items-center justify-center w-8 h-8 rounded-[var(--radius-md)] text-[var(--text-sm)] text-[var(--color-text-tertiary)] cursor-not-allowed">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M6.22 3.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 0 1 0-1.06Z" /></svg>
      </span>
    )}
  </nav>
)}

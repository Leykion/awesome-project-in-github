---
// packages/frontend/src/components/astro/MetricsBar.astro
// 统计指标栏：Stars、Forks、最后提交时间

import { formatNumber, timeAgo } from "@gitpulse/shared";

interface Props {
  /** 总 star 数 */
  stars: number;
  /** 总 fork 数 */
  forks: number;
  /** 最后提交时间 (ISO 8601) */
  pushedAt: string | null;
}

const { stars, forks, pushedAt } = Astro.props;
---

<div class="flex items-center gap-[var(--space-4)] text-[var(--text-sm)] text-[var(--color-text-secondary)]">
  <!-- Stars -->
  <span class="inline-flex items-center gap-[var(--space-1)]">
    <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
    </svg>
    <span class="font-[var(--font-data)]">{formatNumber(stars)}</span>
  </span>

  <!-- Forks -->
  <span class="inline-flex items-center gap-[var(--space-1)]">
    <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 0-1.5 0v.878h-3v-.878a2.25 2.25 0 1 0-1.5 0ZM8 1.25a.75.75 0 0 0-.75.75v.878a2.25 2.25 0 1 0 1.5 0V2A.75.75 0 0 0 8 1.25ZM5.75 9.25a.75.75 0 0 0-.75.75v.878a2.25 2.25 0 1 0 1.5 0V10a.75.75 0 0 0-.75-.75Zm4.5 0a.75.75 0 0 0-.75.75v.878a2.25 2.25 0 1 0 1.5 0V10a.75.75 0 0 0-.75-.75Z" />
    </svg>
    <span class="font-[var(--font-data)]">{formatNumber(forks)}</span>
  </span>

  <!-- 最后提交 -->
  <span class="inline-flex items-center gap-[var(--space-1)]">
    <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Zm7-3.25v2.992l2.028.812a.75.75 0 0 1-.556 1.392l-2.5-1A.75.75 0 0 1 7 8.25v-3.5a.75.75 0 0 1 1.5 0Z" />
    </svg>
    <span>{timeAgo(pushedAt)}</span>
  </span>
</div>

---
// packages/frontend/src/components/astro/HealthBadge.astro
// 维护健康度徽章（green/yellow/red）

import type { HealthBadge } from "@gitpulse/shared";

interface Props {
  /** 健康状态 */
  status: HealthBadge;
}

const { status } = Astro.props;

const config: Record<HealthBadge, { label: string; color: string; bg: string }> = {
  green: { label: "活跃维护", color: "var(--color-health-green)", bg: "rgba(34, 197, 94, 0.12)" },
  yellow: { label: "正常维护", color: "var(--color-health-yellow)", bg: "rgba(234, 179, 8, 0.12)" },
  red: { label: "维护停滞", color: "var(--color-health-red)", bg: "rgba(239, 68, 68, 0.12)" },
};

const { label, color, bg } = config[status];
---

<span
  class="inline-flex items-center gap-[var(--space-1)] rounded-[var(--radius-full)] px-[var(--space-2)] py-0.5 text-[var(--text-xs)] font-medium"
  style={`color: ${color}; background-color: ${bg};`}
>
  <span
    class="inline-block w-1.5 h-1.5 rounded-full"
    style={`background-color: ${color};`}
  ></span>
  {label}
</span>
